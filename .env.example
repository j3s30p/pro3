DISCORD_TOKEN=replace-with-discord-bot-token
DISCORD_GUILD_ID=replace-with-target-guild-id
DISCORD_CHANNEL_IDS=

# Defaults can be changed without code edits.
CRAWL_LIMIT=500
DISCORD_RAW_DIR=data/raw
DISCORD_MARKDOWN_DIR=data/markdown
DISCORD_ATTACHMENTS_DIR=data/attachments
DOWNLOAD_ATTACHMENTS=true

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
CHROMA_PATH=data/chroma
RAG_WINDOW_BEFORE=2
RAG_WINDOW_AFTER=2
RAG_TOP_K=6
RAG_EMBED_BATCH_SIZE=64
RAG_MESSAGE_MAX_ATTACHMENT_CHARS=0
RAG_MAX_ATTACHMENT_TEXT_CHARS=50000
RAG_ATTACHMENT_CHUNK_TOKENS=600
RAG_ATTACHMENT_CHUNK_OVERLAP_TOKENS=80
RAG_MAX_ATTACHMENT_CHUNK_CHARS=4000
RAG_MAX_CHUNK_CHARS=4000
